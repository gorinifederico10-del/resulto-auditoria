# Copiá este archivo como .env y completá los valores reales.
# En Railway estos van en la sección "Variables" del service, no en un archivo.

# REQUERIDO: API key de Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_api_key_aca

# Origenes permitidos por CORS (separados por coma).
# En prod, sumá tu dominio público. Ej: https://resulto.com.ar,https://www.resulto.com.ar
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://resulto.com.ar,https://www.resulto.com.ar

# Token para el endpoint /admin/leads.csv. Inventate una string larga al azar.
ADMIN_TOKEN=cambiame_por_una_string_larga_y_random

# Horas que cachear cada auditoría (mismo URL = mismo resultado durante este lapso).
CACHE_HOURS=24

# Path donde se guarda la base SQLite. En Railway, apuntalo al volume montado.
# Local: dejalo en blanco o "auditorias.db".
DB_PATH=auditorias.db
